# Copy to .env and fill in. Never commit the real .env (it holds your token).

# Public hostname for the hub. A DNS A record must point at this host,
# and ports 80 + 443 must be open for Let's Encrypt + HTTPS.
HUB_DOMAIN=buddy.you.example.com

# Email for Let's Encrypt registration / expiry notices.
ACME_EMAIL=you@example.com

# Shared secret. Required — the hub gates every route with it. Generate one:
#   openssl rand -hex 32
BUDDY_TOKEN=replace-with-a-long-random-secret

# Display name shown on the stick/dashboard. Optional.
HUB_OWNER=you

# Version of buddy-bridge to install in the hub container. Pin to a release
# tag (e.g. v0.1.0) for a reproducible deploy; defaults to main.
BUDDY_REF=main
